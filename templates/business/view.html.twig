{% extends 'base.html.twig' %}

{% block title %}Hello BusinessController!{% endblock %}

{% block body %}
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h3 class="mb-0">Details for Business: {{ business.name }}</h3>
            </div>
            <div class="card-body">
                <p><strong>ID:</strong> {{ business.id }}</p>
                <p><strong>Nume:</strong> {{ business.name }}</p>
                <p><strong>Oras:</strong> {{ business.city }}</p>
                <p><strong>Strada:</strong> {{ business.street }}</p>
                <p><strong>Numar Casa:</strong> {{ business.houseNumber }}</p>
                <p><strong>Telefon:</strong> {{ business.phoneNumber }}</p>
                <p><strong>Tip Business:</strong> {{ business.businessType.name }}</p>
            </div>
            <div class="card-footer d-flex gap-2">
                <a href="{{ path('app_package_new_for_business', { id: business.id }) }}" class="btn btn-success">New package</a>
                <a href="{{ path('app_business_delete', { id: business.id }) }}" class="btn btn-danger">Delete</a>
                <a href="{{ path('app_business') }}" class="btn btn-secondary">Back</a>
            </div>
        </div>
{% endblock %}

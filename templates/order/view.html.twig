{% extends 'base.html.twig' %}

{% block title %}Hello OrderController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
        .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    </style>

    <div class="example-wrapper">
        <p>{{ order.id }}</p>
        <p>{{ order.createdAt ? order.createdAt|date('d-m-y') : '' }}</p>
        <p>{{ order.package.name }}</p>
        <p>{{ order.consumer.firstName }} {{ order.consumer.lastName }}</p>

        <a href="{{ path('app_order_edit', { id: order.id }) }}">Edit</a>
        <a href="{{ path('app_order_delete', { id: order.id }) }}">Delete</a>
        <a href="{{ path('app_order') }}">Back</a>
    </div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Hello OrderController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
        .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
    </style>

    <div class="example-wrapper">
        <a href="{{ path('app_order_new') }}">Create new order</a>
        <table>
            <thead>
            <tr>
                <th>ID</th>
                <th>Created At</th>
                <th>Package</th>
                <th>Consumer</th>
            </tr>
            </thead>
            <tbody>
            {% for order in orders %}
                <tr>
                    <td><a href="{{ path('app_order_view', { id: order.id }) }}">{{ order.id }}</a></td>
                    <td>{{ order.createdAt ? order.createdAt|date('d-m-y') : '' }}</td>
                    <td>{{ order.package.name }}</td>
                    <td>{{ order.consumer.firstName }} {{ order.consumer.lastName }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}

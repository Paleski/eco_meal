{% extends 'base.html.twig' %}

{% block title %}Access Denied{% endblock %}

{% block body %}
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6 text-center mt-5">
                <div class="card shadow border-0 bg-light rounded-4">
                    <div class="card-body p-5">
                        <h1 class="display-1 text-danger fw-bold">403</h1>
                        <h2 class="mb-3 text-dark">Access Denied</h2>
                        <p class="lead text-muted mb-5">
                            Oops! You do not have the required permissions to view this page.
                            Please contact the administrator if you believe this is a mistake.
                        </p>

                        <a href="{{ path('app_package') }}" class="btn btn-primary btn-lg px-4 shadow-sm">
                            Return to Homepage
                        </a>
                    </div>
                </div>
            </div>
        </div>
{% endblock %}

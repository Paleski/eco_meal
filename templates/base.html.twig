<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body class="d-flex flex-column min-vh-100 bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="{{ path('app_package') }}">Eco Meal</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    {% if is_granted("ROLE_ADMIN") %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_business') }}">Businesses</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_category') }}">Categories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_consumer') }}">Consumers</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_order') }}">Orders</a>
                        </li>
                    {% endif %}
                    {% if is_granted("ROLE_BUSINESS") %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_business') }}">Business</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_package') }}">Packages</a>
                        </li>
                    {% endif %}
                    {% if is_granted("ROLE_CONSUMER") %}
                        <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_package') }}">Packages</a>
                        </li>
                        <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_consumer') }}">Consumer</a>
                        </li>
                    {% endif %}
                    {% if not app.user %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_package') }}">Packages</a>

                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_login') }}">Login</a>
                        </li>
                        <li>
                            <a class="nav-link" href="{{ path('app_register') }}">Register</a>
                        </li>
                    {% else %}
                    <li>
                        <a class="nav-link" href="{{ path('app_logout') }}">Logout</a>
                    </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <main class="container my-4 flex-grow-1">
        {% block body %}
        {% endblock %}
    </main>

    <footer class="bg-white text-center py-3 border-top mt-auto">
        <div class="container text-muted">
            <small>&copy; {{ 'now'|date('Y') }} Eco Meal</small>
        </div>
    </footer>

    </body>
</html>
